{
    "id": "ai-tools",
    "version": "1.0.6",
    "name": "Ai-Tools",
    "documentationURL": "https://github.com/bobrossthepainter/devcontainer-features",
    "options": {
        "claude": {
            "type": "boolean",
            "default": false,
            "description": "Install Claude Code CLI?"
        },
        "codex": {
            "type": "boolean",
            "default": false,
            "description": "Install OpenAI Codex CLI?"
        },
        "pi": {
            "type": "boolean",
            "default": false,
            "description": "Install Pi Coding Agent Harness?"
        }
    },
    "containerEnv": {
        "PATH": "~/.claude/local/bin:~/.local/bin:${PATH}"
    },
    "installsAfter": [
        "ghcr.io/devcontainers/features/common-utils",
        "ghcr.io/devcontainers/features/node"
    ]
}
